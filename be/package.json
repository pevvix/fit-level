{
  "name": "fit-level-be",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "artur",
  "type": "module",
  "scripts": {
    "db:create": "dbmate -d ./db-migrations new",
    
    "db:migrate": "dotenv -e .env -- dbmate -d ./db-migrations --no-dump-schema up",
    
    "db:clean:test": "dotenv -e .env.test -- dbmate drop || true",
    "db:migrate:test": "dotenv -e .env.test -- dbmate -d ./db-migrations --no-dump-schema up",
    
    "test": "npm run db:clean:test && npm run db:migrate:test && NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules npx jest --detectOpenHandles --forceExit" ,
    
    "dev": "npm run db:migrate && dotenv -e .env -- tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "sqlite3": "^6.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "dbmate": "^2.32.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
